# ── Binaries ──────────────────────────────────────────────────────────────────
bin/
dist/
/oc             # root-level oc binary

# Go artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# ── Database / runtime data ───────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
.opencontext/           # all OpenContext runtime data (events.db, memory.md, hooks)

# Generated memory / context files (written by oc daemon at runtime)
memory.md
**/memory.md
**/.hermes.md

# ── Config files that may contain local paths or secrets ─────────────────────
# Use the *.example.yaml / *.example.json templates as reference.
config.yaml
config.local.yaml
*.local.yaml
*.local.json
# Collector-specific user configs (not the bundled *.example.yaml)
collectors/**/*-collector.yaml
collectors/**/collector.yaml
# Python virtual environments inside collector dirs
collectors/**/.venv/
collectors/**/__pycache__/
collectors/**/*.pyc
collectors/**/*.pyo
collectors/**/*.pyd

# ── Shell hook adapters written by `oc collector * install` ──────────────────
# These are written to ~/.opencontext/collectors/*/; the sources live here.
.opencontext/collectors/

# ── Editor / OS ───────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Test / scratch files ──────────────────────────────────────────────────────
test_ref.md
coverage.out
coverage.html
